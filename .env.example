# ─────────────────────────────────
# 서버
# ─────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000                     # legacy apps/server 포트 (사용 중단 예정)

# ─────────────────────────────────
# Phase 2-E: 분리 진입점 포트
# ─────────────────────────────────
CORE_PORT=3001                # apps/core-server 포트 (OCPP WebSocket + Internal API)
PORTAL_PORT=3002              # apps/portal-server 포트 (REST API + Portal)
LEGACY_PORT=3000              # apps/server (레거시 통합 포트, 개발용)

# ─────────────────────────────────
# 데이터베이스
# ─────────────────────────────────
DATABASE_URL=postgresql://pvpentech:password@localhost:5432/pvpentech_db

# ─────────────────────────────────
# Redis
# ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────
# 인증 (JWT)
# ─────────────────────────────────
JWT_SECRET=your-very-long-random-secret-key-at-least-32-chars
JWT_EXPIRES_IN=24h

# ─────────────────────────────────
# OCPP
# ─────────────────────────────────
OCPP_RESPONSE_TIMEOUT_MS=30000    # CP 응답 대기 최대 시간 (ms)
OCPP_HEARTBEAT_INTERVAL_SEC=60    # Heartbeat 주기 (초)

# ─────────────────────────────────
# 요금 설정
# ─────────────────────────────────
DEFAULT_UNIT_PRICE_KRW=250        # 기본 충전 단가 (원/kWh)

# ─────────────────────────────────
# 로깅
# ─────────────────────────────────
LOG_LEVEL=info                    # fatal | error | warn | info | debug | trace
LOG_PRETTY=true                   # 개발 시 가독성 향상 (프로덕션: false)

# ─────────────────────────────────
# CORS
# ─────────────────────────────────
CORS_ORIGIN=https://www.pvpentech.com,https://pvpentech.com

# ─────────────────────────────────
# 프로비저닝
# ─────────────────────────────────
CSMS_SERVER_URL=wss://pvpentech.example.com
PROVISION_ALLOWED_CIDRS=          # 빈값 = 모두 허용, "1.2.3.0/24,5.6.7.0/24" 형식

# ─────────────────────────────────
# Swagger API 문서 (/api-docs) - HTTP Basic Auth
# ─────────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASSWORD=pvpentech       # 운영 환경에서 반드시 변경

# ─────────────────────────────────
# 환불 배치 (Dispatcher + Worker pool)
# ─────────────────────────────────
REFUND_ATTEMPT_CONCURRENCY=5          # refund-attempt 큐 워커 동시 처리 수 (1-50, 기본 5)
REFUND_DISPATCH_CHUNK_SIZE=500        # dispatcher addBulk 청크 크기 (1-5000, 기본 500)
REFUND_DISPATCH_MAX_CANDIDATES=10000  # dispatcher 1회 조회 상한 — 기본 10000, 운영에서 조정 가능

# MB Bank (결제 / 정산 송금)
# ─────────────────────────────────
MB_BANK_IS_MOCK=true              # true 시 실제 MB Bank API 미호출 (개발/테스트용)
# 아래 4개는 실 MB Bank Corporate Transfer API 연동 시 설정 (MB_BANK_IS_MOCK=false)
MB_BANK_TRANSFER_URL=
MB_BANK_TRANSFER_MERCHANT_ID=
MB_BANK_TRANSFER_ACCESS_CODE=
MB_BANK_TRANSFER_HASH_KEY=

# ─────────────────────────────────
# Phase 2-B: Internal API (Portal → Core 서비스 간 통신)
# ─────────────────────────────────
CSMS_INTERNAL_API_TOKEN=replace_me_with_a_long_random_string_min_32_chars
# Phase 2-E 이후: Portal → Core 호출 URL = Core 서버 주소 (포트 3001 기본)
CSMS_INTERNAL_API_BASE_URL=http://localhost:3001/api/internal/v1
