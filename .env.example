# ─────────────────────────────────
# 서버 (Core)
# ─────────────────────────────────
NODE_ENV=development          # development | production | test
CORE_PORT=3001                # OCPP WebSocket + Internal API 포트
TIMEZONE=Asia/Ho_Chi_Minh     # 비즈니스 TZ; 통계/집계 경계 해석 기준 (IANA Time Zone 식별자)
# MB_BANK_TZ=Asia/Ho_Chi_Minh   # 미설정 시 TIMEZONE 값을 사용 (MB Bank 연동 전용 TZ override)

# ─────────────────────────────────
# 데이터베이스
# ─────────────────────────────────
DATABASE_URL=postgresql://pvpentech:password@localhost:5432/pvpentech_db

# ─────────────────────────────────
# Redis
# ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────
# OCPP
# ─────────────────────────────────
OCPP_RESPONSE_TIMEOUT_MS=30000    # CP 응답 대기 최대 시간 (ms)
OCPP_HEARTBEAT_INTERVAL_SEC=60    # Heartbeat 주기 (초)

# ─────────────────────────────────
# 요금 설정
# ─────────────────────────────────
DEFAULT_UNIT_PRICE_KRW=250        # 기본 충전 단가 (원/kWh)

# ─────────────────────────────────
# 로깅
# ─────────────────────────────────
LOG_LEVEL=info                    # fatal | error | warn | info | debug | trace
LOG_PRETTY=true                   # 개발 시 가독성 향상 (프로덕션: false)

# ─────────────────────────────────
# CORS
# ─────────────────────────────────
CORS_ORIGIN=https://www.pvpentech.com,https://pvpentech.com

# ─────────────────────────────────
# 프로비저닝
# ─────────────────────────────────
CSMS_SERVER_URL=wss://pvpentech.example.com
PROVISION_ALLOWED_CIDRS=          # 빈값 = 모두 허용, "1.2.3.0/24,5.6.7.0/24" 형식

# ─────────────────────────────────
# Swagger API 문서 (/api-docs) - HTTP Basic Auth
# ─────────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASSWORD=pvpentech       # 운영 환경에서 반드시 변경

# ─────────────────────────────────
# Internal API (Portal → Core 서비스 간 통신)
# ─────────────────────────────────
# Portal과 동일한 값을 사용해야 함
CSMS_INTERNAL_API_TOKEN=replace_me_with_a_long_random_string_min_32_chars
