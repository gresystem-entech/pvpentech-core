{
  "name": "pvpentech-core",
  "version": "1.0.0",
  "description": "Pvpentech CSMS Core — OCPP 1.6 WebSocket Gateway + Internal API + Outbox Relay",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register apps/core-server/src/index.ts",
    "dev:core": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register apps/core-server/src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node -r module-alias/register dist/apps/core-server/src/index.js",
    "start:core": "node -r module-alias/register dist/apps/core-server/src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"apps/*/src/**/*.ts\" --ext .ts",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"apps/*/src/**/*.ts\"",
    "validate-translations": "ts-node -r tsconfig-paths/register scripts/validateTranslations.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "i18next": "^23.10.0",
    "i18next-fs-backend": "^2.3.1",
    "i18next-http-middleware": "^3.6.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "multer": "^2.1.1",
    "pino": "^8.19.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.2.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  },
  "_moduleAliases": {
    "@pvpentech/shared": "dist/packages/shared/src",
    "@pvpentech/core": "dist/packages/core/src",
    "@core": "dist/packages/core/src",
    "@shared": "dist/packages/shared/src"
  }
}
